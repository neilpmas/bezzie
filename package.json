{
  "name": "bezzie",
  "version": "1.0.1",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "description": "BFF OAuth 2.0 auth library for Cloudflare Workers",
  "keywords": [
    "bff",
    "backend-for-frontend",
    "jwt",
    "pkce",
    "token-rotation",
    "oidc",
    "cloudflare-workers",
    "oauth2",
    "auth",
    "hono",
    "oauth",
    "session"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cloudflare": {
      "import": "./dist/adapters/cloudflare-kv.js",
      "types": "./dist/adapters/cloudflare-kv.d.ts"
    },
    "./redis": {
      "import": "./dist/adapters/redis.js",
      "types": "./dist/adapters/redis.d.ts"
    },
    "./memory": {
      "import": "./dist/adapters/memory.js",
      "types": "./dist/adapters/memory.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neilpmas/bezzie"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "prepublishOnly": "npm run build && npm test && npm run lint"
  },
  "dependencies": {
    "oauth4webapi": "^3.8.5"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.1",
    "wrangler": "^4.77.0"
  }
}
